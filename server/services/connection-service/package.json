{
  "name": "connection-service",
  "version": "1.0.0",
  "type": "module",
  "description": "WIE Connection Service with gRPC and REST API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:trace": "node --trace-warnings ./node_modules/.bin/tsx src/index.ts",
