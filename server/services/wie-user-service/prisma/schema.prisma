generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryCode String    @unique @map("country_code") @db.VarChar(10)
  countryName String    @map("country_name") @db.VarChar(100)
  phoneCode   String?   @map("phone_code") @db.VarChar(10)  
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  
  // Relations
  users       WieUser[]
  
  @@map("countries")
}

model WieUser {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String?   @unique @db.VarChar(255)
  contactNo       String?   @unique @map("contact_no") @db.VarChar(20)
  password        String?   @db.VarChar(255)  // Made nullable for OAuth users
  name            String?   @db.VarChar(255)
  username        String?   @unique @db.VarChar(100)
  profilePicture  String?   @map("profile_picture") @db.Text
  countryId       String?   @map("country_id") @db.Uuid
  role            String    @default("user") @db.VarChar(50)
  status          String    @default("pending") @db.VarChar(20)
  bio             String?   @db.Text
  location        String?   @db.Text
  followingCount  Int       @default(0) @map("following_count")
  followersCount  Int       @default(0) @map("followers_count")
  postsCount      Int       @default(0) @map("posts_count")
  latitude        Float?    @map("latitude")  @db.DoublePrecision
  longitude       Float?    @map("longitude") @db.DoublePrecision
  isOnline        Boolean   @default(false) @map("is_online")
  isBlocked       Boolean   @default(false) @map("is_blocked")
  isVerified      Boolean   @default(false) @map("is_verified")
  googleId        String?   @unique @map("google_id") @db.VarChar(255)  // NEW: Google OAuth ID
  authProvider    String    @default("local") @map("auth_provider") @db.VarChar(20)  // NEW: 'local' or 'google'
  tokenVersion    Int      @default(0) @map("token_version") 
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  // Relations
  country         Country?  @relation(fields: [countryId], references: [id], onDelete: SetNull)
  otps            Otp[]
  
  @@map("wie_users")
}

model Otp {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  tempId    String?  @map("temp_id") @db.VarChar(255)
  otpValue  String   @map("otp_value") @db.VarChar(6)
  otpType   String   @default("signup") @map("otp_type") @db.VarChar(20)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  
  // Relations
  user      WieUser? @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId], map: "idx_otps_user_id")
  @@index([tempId], map: "idx_otps_temp_id")
  @@index([expiresAt], map: "idx_otps_expires_at")
  @@map("otps")
}
